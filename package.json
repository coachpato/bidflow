{
  "name": "bidflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-with-db-env.js \"prisma generate && next build\"",
    "db:migrate:deploy": "node scripts/run-with-db-env.js \"prisma migrate deploy\"",
    "db:migrate:status": "node scripts/run-with-db-env.js \"prisma migrate status\"",
    "db:validate": "node scripts/run-with-db-env.js \"npx prisma validate\"",
    "db:pull": "node scripts/run-with-db-env.js \"prisma db pull\"",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.102.1",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "iron-session": "^8.0.4",
    "next": "16.2.2",
    "pdf-parse": "^2.4.5",
    "prisma": "5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^29.7.0",
    "tailwindcss": "^4"
  }
}
